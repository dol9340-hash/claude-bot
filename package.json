{
  "name": "claude-bot",
  "version": "0.2.0",
  "description": "Conversation-driven development orchestrator — Web Dashboard",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claudebot": "dist/index.js"
  },
  "scripts": {
    "dev": "cd dashboard && npm run dev",
    "build": "tsc && cd dashboard && npm run build",
    "start": "cd dashboard && npm start",
    "typecheck": "tsc --noEmit && cd dashboard && npm run typecheck",
    "test": "vitest run",
    "test:ci": "vitest run --exclude tests/e2e/sdk-real.test.ts",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  }
}
